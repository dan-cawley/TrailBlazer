# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Supabase Postgres connection string for Prisma (Project Settings > Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?schema=public

# Create this private bucket in Supabase Storage before uploading district calendars.
SUPABASE_CALENDAR_BUCKET=district-calendars
SUPABASE_CURRICULUM_BUCKET=curriculum-files
